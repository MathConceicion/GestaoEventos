@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-5">

                <div class="text-center mb-4">
                    <h1 class="fw-bold fs-3 mb-1">Bem-vindo de volta</h1>
                    <p class="text-muted small">Entre com sua conta local para continuar</p>
                </div>

                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <div class="card-body">
                        <section>
                            <form id="account" method="post">

                                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                                <div class="mb-3">
                                    <label asp-for="Input.Email" class="form-label fw-semibold small text-uppercase text-muted ls-1">Email</label>
                                    <input asp-for="Input.Email"
                                           class="form-control form-control-lg rounded-3"
                                           autocomplete="username"
                                           aria-required="true"
                                           placeholder="nome@exemplo.com" />
                                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Input.Password" class="form-label fw-semibold small text-uppercase text-muted">Senha</label>
                                    <input asp-for="Input.Password"
                                           class="form-control form-control-lg rounded-3"
                                           autocomplete="current-password"
                                           aria-required="true"
                                           placeholder="••••••••" />
                                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                                </div>

                                <div class="mb-4 form-check">
                                    <input class="form-check-input" asp-for="Input.RememberMe" />
                                    <label class="form-check-label small text-muted" asp-for="Input.RememberMe">
                                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                                    </label>
                                </div>

                                <button id="login-submit" type="submit" class="btn btn-dark w-100 btn-lg rounded-3 fw-semibold mb-3">
                                    Entrar
                                </button>

                                <div class="d-flex flex-column gap-1 text-center">
                                    <a id="forgot-password" asp-page="./ForgotPassword" class="text-muted small text-decoration-none">Esqueceu sua senha?</a>
                                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-muted small text-decoration-none">Criar uma nova conta</a>
                                    <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="text-muted small text-decoration-none">Reenviar confirmação de e-mail</a>
                                </div>

                            </form>
                        </section>

                        <hr class="my-4 text-muted" />

                        <section>
                            <p class="text-center text-muted small fw-semibold text-uppercase mb-3">Ou entre com</p>
                            @{
                                if ((Model.ExternalLogins?.Count ?? 0) == 0)
                                {
                                    <p class="text-muted small text-center">
                                        Nenhum provedor externo configurado.
                                        <a href="https://go.microsoft.com/fwlink/?LinkID=532715" class="text-decoration-none">Saiba como configurar</a>.
                                    </p>
                                }
                                else
                                {
                                    <form id="external-account"
                                          asp-page="./ExternalLogin"
                                          asp-route-returnUrl="@Model.ReturnUrl"
                                          method="post">
                                        <div class="d-flex flex-wrap gap-2 justify-content-center">
                                            @foreach (var provider in Model.ExternalLogins!)
                                            {
                                                <button type="submit"
                                                        class="btn btn-outline-secondary rounded-3 px-4"
                                                        name="provider"
                                                        value="@provider.Name"
                                                        title="Entrar com @provider.DisplayName">
                                                    @provider.DisplayName
                                                </button>
                                            }
                                        </div>
                                    </form>
                                }
                            }
                        </section>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}