@page
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Reenviar e-mail de confirmação";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12 col-md-5">

        <div class="text-center mb-4">
          <h1 class="fw-bold fs-3 mb-1">Reenviar confirmação</h1>
          <p class="text-muted small">Digite seu e-mail para receber um novo link de confirmação</p>
        </div>

        <div class="card border-0 shadow-sm rounded-4 p-4">
          <div class="card-body">
            <form method="post">

              <div class="mb-4">
                <label asp-for="Input.Email" class="form-label fw-semibold small text-uppercase text-muted">Email</label>
                <input asp-for="Input.Email"
                       class="form-control form-control-lg rounded-3"
                       aria-required="true"
                       placeholder="nome@exemplo.com" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
              </div>

              <button type="submit" class="btn btn-dark w-100 btn-lg rounded-3 fw-semibold mb-3">
                Reenviar e-mail
              </button>

              <div class="text-center">
                <a asp-page="./Login" class="text-muted small text-decoration-none">Voltar para o login</a>
              </div>

            </form>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}