@page
@model RegisterModel
@{
    ViewData["Title"] = "Registrar";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-5">

                <div class="text-center mb-4">
                    <h1 class="fw-bold fs-3 mb-1">Criar uma conta</h1>
                    <p class="text-muted small">Preencha os dados abaixo para se registrar</p>
                </div>

                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <div class="card-body">

                        <section>
                            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">

                                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                                <div class="mb-3">
                                    <label asp-for="Input.Email" class="form-label fw-semibold small text-uppercase text-muted">Email</label>
                                    <input asp-for="Input.Email"
                                           class="form-control form-control-lg rounded-3"
                                           autocomplete="username"
                                           aria-required="true"
                                           placeholder="nome@exemplo.com" />
                                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Input.Password" class="form-label fw-semibold small text-uppercase text-muted">Senha</label>
                                    <input asp-for="Input.Password"
                                           class="form-control form-control-lg rounded-3"
                                           autocomplete="new-password"
                                           aria-required="true"
                                           placeholder="••••••••" />
                                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                                </div>

                                <div class="mb-4">
                                    <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold small text-uppercase text-muted">Confirmar Senha</label>
                                    <input asp-for="Input.ConfirmPassword"
                                           class="form-control form-control-lg rounded-3"
                                           autocomplete="new-password"
                                           aria-required="true"
                                           placeholder="••••••••" />
                                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                                </div>

                                <button id="registerSubmit" type="submit" class="btn btn-dark w-100 btn-lg rounded-3 fw-semibold mb-3">
                                    Criar conta
                                </button>

                                <div class="text-center">
                                    <a asp-page="./Login" class="text-muted small text-decoration-none">Já tem uma conta? Entrar</a>
                                </div>

                            </form>
                        </section>

                        <hr class="my-4 text-muted" />

                        <section>
                            <p class="text-center text-muted small fw-semibold text-uppercase mb-3">Ou registre-se com</p>
                            @{
                                if ((Model.ExternalLogins?.Count ?? 0) == 0)
                                {
                                    <p class="text-muted small text-center">
                                        Nenhum provedor externo configurado.
                                        <a href="https://go.microsoft.com/fwlink/?LinkID=532715" class="text-decoration-none">Saiba como configurar</a>.
                                    </p>
                                }
                                else
                                {
                                    <form id="external-account"
                                          asp-page="./ExternalLogin"
                                          asp-route-returnUrl="@Model.ReturnUrl"
                                          method="post">
                                        <div class="d-flex flex-wrap gap-2 justify-content-center">
                                            @foreach (var provider in Model.ExternalLogins!)
                                            {
                                                <button type="submit"
                                                        class="btn btn-outline-secondary rounded-3 px-4"
                                                        name="provider"
                                                        value="@provider.Name"
                                                        title="Registrar com @provider.DisplayName">
                                                    @provider.DisplayName
                                                </button>
                                            }
                                        </div>
                                    </form>
                                }
                            }
                        </section>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}