@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Confirmação de esquecimento de senha";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-5">

                <div class="card border-0 shadow-sm rounded-4 p-4 text-center">
                    <div class="card-body py-4">

                        <div class="mb-3">
                            <i class="bi bi-envelope-check" style="font-size: 3rem;"></i>
                        </div>

                        <h1 class="fw-bold fs-3 mb-2">Verifique seu e-mail</h1>
                        <p class="text-muted small mb-4">
                            Enviamos um link de redefinição de senha para o seu e-mail. Verifique sua caixa de entrada e siga as instruções.
                        </p>

                        <a asp-page="./Login" class="btn btn-dark w-100 btn-lg rounded-3 fw-semibold mb-3">
                            Voltar para o login
                        </a>

                        <div class="text-center">
                            <a asp-page="./ForgotPassword" class="text-muted small text-decoration-none">Não recebeu? Tentar novamente</a>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>