@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Acesso negado";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-5">

                <div class="card border-0 shadow-sm rounded-4 p-4 text-center">
                    <div class="card-body py-4">

                        <div class="mb-3 text-danger">
                            <i class="bi bi-shield-x" style="font-size: 3rem;"></i>
                        </div>

                        <h1 class="fw-bold fs-3 mb-2">Acesso negado</h1>
                        <p class="text-muted small mb-4">
                            Você não tem permissão para acessar este recurso.
                        </p>

                        <a asp-page="/Index" class="btn btn-dark w-100 btn-lg rounded-3 fw-semibold mb-3">
                            Voltar para o início
                        </a>

                        <div class="text-center">
                            <a asp-page="./Login" class="text-muted small text-decoration-none">Entrar com outra conta</a>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>